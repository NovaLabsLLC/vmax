{
  "name": "vmax",
  "version": "0.1.0",
  "description": "Jarvis-like always-on-top macOS bottom-bar AI assistant",
  "main": "electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5180 && cross-env NODE_ENV=development node scripts/run-electron.cjs",
    "dev": "concurrently -k -n RENDERER,ELECTRON -c blue,magenta \"npm:dev:renderer\" \"npm:dev:electron\"",
    "build:renderer": "vite build",
    "build": "npm run build:renderer",
    "start": "cross-env NODE_ENV=production node scripts/run-electron.cjs"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.2",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  }
}
