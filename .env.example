# Provide one of these. OpenAI is used by default for both vision + Whisper.
OPENAI_API_KEY=

# Optional: if set, Claude is used for vision/reasoning instead of OpenAI.
# Whisper still uses OPENAI_API_KEY (no Anthropic STT yet).
ANTHROPIC_API_KEY=

# Optional: OpenClaw CLI bridge (Workspace → "Run in OpenClaw"). Defaults shown.
# OPENCLAW_BIN=openclaw
# OPENCLAW_TIMEOUT_SEC=900
# OPENCLAW_AGENT=
