# Vmax backend URL — the FastAPI service in ./backend that owns the
# OpenAI / Anthropic API keys. The desktop app no longer holds them.
# Run `cd backend && uvicorn app.main:app --reload` (see backend/README.md).
VMAX_BACKEND_URL=http://127.0.0.1:8000

# Legacy keys — still read by other parts of the app (Claude/Codex/Cursor
# CLI auth detection, and the in-app Settings panel). They are NOT used
# for AI calls anymore; the backend reads its own copy from backend/.env.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Anthropic Claude Code CLI (Workspace → "Send to Claude Code").
# Defaults to `claude` on your PATH. Use an absolute path if the GUI app doesn't inherit your shell PATH:
# CLAUDE_BIN=/usr/local/bin/claude

# Optional: OpenClaw CLI bridge (Workspace → "Run in OpenClaw"). Defaults shown.
# OPENCLAW_BIN=openclaw
# OPENCLAW_TIMEOUT_SEC=900
# OPENCLAW_AGENT=
