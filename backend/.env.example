# Vmax backend — copy to .env and fill in.
# Both keys are read at process start; aiClient.py reuses them per request.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional model overrides — defaults match the previous Electron client.
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MODEL_TEXT=gpt-4o-mini
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Task planner uses the cheap/fast variants (POST /v1/task). Override
# only if you want a snappier or smarter task pre-classifier.
# OPENAI_MODEL_TASK=gpt-4o-mini
# ANTHROPIC_MODEL_TASK=claude-haiku-4-5-20251001

# Optional CORS — comma-separated origins allowed to call this API.
# Defaults cover Electron file:// and the Vite dev server.
# VMAX_ALLOWED_ORIGINS=http://localhost:5180,http://localhost:5181

# Bind address for uvicorn (default 127.0.0.1:8000).
# VMAX_HOST=127.0.0.1
# VMAX_PORT=8000
